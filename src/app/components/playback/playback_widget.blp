using Gtk 4.0;
using Adw 1;

template $PlaybackWidget : Box {
  orientation: vertical;

  Scale seek_bar {
    show-fill-level: true;
    restrict-to-fill-level: false;
    fill-level: 0;
    digits: 0;
    value-pos: left;

    styles [
      "seek-bar",
    ]
  }

  Box {
    margin-top: 0;
    margin-bottom: 0;
    margin-start: 10;
    margin-end: 10;

    Label track_position {
      sensitive: false;
      label: "0∶00";
      halign: start;
      hexpand: true;

      styles [
        "numeric",
      ]
    }

    Label track_duration {
      sensitive: false;
      label: "0∶00";
      halign: end;

      styles [
        "numeric",
      ]
    }
  }

  Adw.BreakpointBin {
    width-request: 1;
    height-request: 1;

    Adw.Breakpoint {
      condition("max-width:800sp")

      setters {
        volume-stack.visible-child-name: 'slider-button';
      }
    }

    child: CenterBox {
      hexpand: true;
      shrink-center-last: true;

      start-widget: $PlaybackInfoWidget now_playing {
        hexpand: true;
        halign: fill;
        valign: center;
      };

      center-widget: Box {
        halign: center;
        valign: center;
        spacing: 20;

        $DeviceSelectorWidget device_selector {
        }

        $PlaybackControlsWidget controls {
          halign: center;
        }

        Button queue {
          receives-default: true;
          halign: center;
          valign: center;
          has-frame: false;
          icon-name: "view-list-bullet-symbolic";
          tooltip-text: _("Queue");
        }
      };

      end-widget: Stack volume-stack {
        visible-child-name: "slider";
        hexpand: true;
        halign: end;
        valign: center;

        StackPage {
          name: 'slider';
          child: Box {
            Image {
              icon-name: 'audio-volume-high-symbolic';
            }

            Scale volume_slider {
              width-request: 150;
              show-fill-level: true;
              restrict-to-fill-level: false;
              value-pos: left;

              styles [
                'volume-slider'
              ]

              adjustment: Adjustment {
                lower: 0.0;
                value: 0.7;
                upper: 1.0;
                step-increment: 0.01;
                page-increment: 0.05;
              };
            }
          };
        }

        StackPage {
          name: 'slider-button';
          child: Box {
            halign: end;
            valign: center;
            margin-end: 10;
            MenuButton {
              direction: up;
              icon-name: 'audio-volume-high-symbolic';
              halign: end;
              styles [
                "flat"
              ]
              popover: Popover{
                position: top;
                child: Scale {
                  inverted: true;
                  orientation: vertical;
                  height-request: 160;
                  adjustment: bind volume_slider.adjustment;
                };
              };
            }
          };
        }
      };
    };
  }
}
