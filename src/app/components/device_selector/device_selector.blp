using Gtk 4.0;
using Adw 1;

template $DeviceSelectorWidget : Button {
  Adw.ButtonContent button_content {
    halign: center;
    hexpand: false;
    icon-name: "audio-x-generic-symbolic";
  }
}

menu menu {
  section {
    label: _("Playing on");

    item {
      custom: "custom_content";
    }
  }
}

PopoverMenu popover {
}

Box custom_content {
  orientation: vertical;

  Box devices {
    orientation: vertical;
  }
}
